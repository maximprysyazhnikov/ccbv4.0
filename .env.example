# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
BOT_MODE=polling
# BOT_MODE=webhook
# WEBHOOK_URL=https://your-domain.com/webhook
# PORT=8080

# Timezone and Locale
TZ_NAME=Europe/Kyiv
DEFAULT_LOCALE=uk

# Monitored Symbols (comma-separated)
MONITORED_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,LTCUSDT,XLMUSDT,LINKUSDT,FOGOUSDT,DOGEUSDT,AVAXUSDT,DOTUSDT,NEARUSDT,ARBUSDT,OPUSDT,SUIUSDT,APTUSDT,TONUSDT,TRXUSDT
METALS_SYMBOLS=XAUUSD,XAGUSD,XPTUSD,XPDUSD
METALS_SCALP_TIMEFRAME=5m
METALS_SCALP_SL_PCT=0.35
METALS_SCALP_TP_PCT=0.90
METALS_SCALP_MIN_GATE_PCT=72
METALS_SCALP_MIN_ADX=18
METALS_SCALP_MAX_RSI_LONG=72
METALS_SCALP_MIN_RSI_SHORT=28
METALS_AUTOPOST_ENABLED=true
METALS_AUTOPOST_INTERVAL_SEC=600
METALS_AUTOPOST_OPEN_TRADES=false
METALS_SIGNAL_ONLY=true
METALS_AUTOPOST_CHAT_ID=

# Analysis Settings
ANALYZE_TIMEFRAME=15m
ANALYZE_LIMIT=150

# OpenRouter Configuration
# Option 1: Simple format
OPENROUTER_KEYS=your_openrouter_key_1,your_openrouter_key_2
OPENROUTER_MODEL=deepseek/deepseek-chat,openai/gpt-4o-mini
OPENROUTER_BASE=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=30

# Option 2: JSON format (alternative to above)
# OR_SLOTS=[{"key":"your_openrouter_key","model":"deepseek/deepseek-chat","base":"https://openrouter.ai/api/v1","timeout":30}]

# Database Configuration
DB_PATH=storage/bot.db
# Alternative paths (checked in order):
# - DB_PATH environment variable
# - /data/bot.db (Railway volume)
# - ./data/bot.db (local fallback)
DB_POOL_SIZE=5

# Auto-Post Settings
AUTOPOST_INTERVAL_SEC=300
AUTOPOST_DISABLE_SHORTS=false
SHORT_SIGNAL_ONLY=true
PAPER_CAPTURE_WHILE_PAUSED=true
NEAR_MISS_PAPER_ENABLED=true
NEAR_MISS_GATE_GAP_POINTS=1.0
NEAR_MISS_ALLOW_HARD_BLOCKERS=true
AUTOPOST_PERF_EPOCH_TS=
PAPER_RELEASE_MIN_CLOSED=20
PAPER_RELEASE_MIN_WR=0.35
PAPER_RELEASE_MIN_PNL_R=0.0
PAPER_RELEASE_MIN_AVG_R=0.0
ALLOWLIST_PROPOSAL_NOTIFY_ENABLED=true
ALLOWLIST_PROPOSAL_NOTIFY_INTERVAL_SEC=1800
ALLOWLIST_PROPOSAL_LOOKBACK_HOURS=168
MAX_OPEN_PER_RUN=2
MAX_OPEN_PER_DAY=6
METALS_MAX_OPEN_PER_DAY=33
AUTOPOST_LOW_WR_BLOCK=true
AUTOPOST_LOW_WR_WINDOW=20
AUTOPOST_LOW_WR_MIN=0.35
AUTOPOST_LOW_WR_PAUSE_MIN=0.20
AUTOPOST_RECOVERY_ENABLED=true
AUTOPOST_RECOVERY_WR_MIN=0.35
AUTOPOST_RECOVERY_MAX_MESSAGES_PER_RUN=1
AUTOPOST_RECOVERY_MAX_OPEN_PER_RUN=1
AUTOPOST_RECOVERY_MAX_OPEN_PER_DAY=2
SYMBOL_COOLDOWN_AFTER_SL_MIN=60
SYMBOL_MAX_CONSECUTIVE_SL=3
SYMBOL_CONSECUTIVE_SL_COOLDOWN_MIN=360
SYMBOL_BAN_MIN_TRADES=4
SYMBOL_BAN_LOOKBACK=12
SYMBOL_BAN_MAX_PNL=-2.0
SYMBOL_BAN_COOLDOWN_MIN=720
LONG_ONLY_QUALITY_ENABLED=true
LONG_ONLY_MIN_ADX=22
LONG_ONLY_MIN_VOL_RATIO=0.90
LONG_ONLY_MAX_VWAP_DELTA_PCT=0.30
LONG_ONLY_MAX_BB_PCT_B=0.80
MARKET_REGIME_FILTER_ENABLED=true
REGIME_LONG_ALLOWED=TREND_UP
REGIME_SHORT_ALLOWED=TREND_DOWN
REGIME_LOW_LIQUIDITY_VOL_RATIO=0.50
REGIME_CHOP_ADX=16
REGIME_TREND_ADX=22
EV_FILTER_ENABLED=true
EV_MIN_TRADES=8
EV_LOOKBACK=50
EV_MIN_R=0.0
#
# Direction edge guard: blocks a weak recent LONG/SHORT stream without removing symbols.
DIRECTION_EDGE_GUARD_ENABLED=true
DIRECTION_EDGE_GUARD_LOOKBACK=6
DIRECTION_EDGE_GUARD_MIN_TRADES=4
DIRECTION_EDGE_GUARD_MIN_WR=0.15
DIRECTION_EDGE_GUARD_MIN_SUM_R=-3.0
AUTOPOST_COOLDOWN_MIN=30
DEDUP_WINDOW_SEC=90

# Trading Settings
PROFIT_GUARD_MIN_GATE_PCT=70
MOVE_SL_TO_BE_AT_RR=1.0
PARTIAL_TP_ENABLED=true
PARTIAL_TP_AT_RR=1.0
PARTIAL_TP_CLOSE_PCT=0.5
LOCK_PROFIT_AT_RR=1.5
LOCK_PROFIT_R=0.3
TRAIL_AFTER_RR=2.0
RR_THRESHOLD=1.5
RISK_PER_TRADE=0.0075
PARTIAL_TP_PCT=0.5
MOVE_BE_AT_RR=1.0

# Profit Guard (strict only when Scalping=ON)
PROFIT_GUARD_ENABLED=true
PROFIT_GUARD_STANDARD_ENABLED=false
PROFIT_GUARD_BLOCKED_SYMBOLS=ETHUSDT,BNBUSDT,LTCUSDT
PROFIT_GUARD_HOURS=13,14,15,16
PROFIT_GUARD_MIN_GATE_PCT=72
PROFIT_GUARD_SHORT_EXTRA_GATE_PCT=5
PROFIT_GUARD_SHORT_RR_BONUS=0.10
PROFIT_GUARD_MIN_ADX=22
PROFIT_GUARD_MIN_VOL_RATIO=0.9
AUTOPOST_STABLE_CHECKS=1
ALERTS_REPEAT_MIN=180
WR_REPEAT_MIN=180
SCALP_VOL_RATIO_HARD_MIN=0.60
SCALP_RSI_LONG_HARD_MAX=68
SCALP_RSI_SHORT_HARD_MIN=30
SCALP_BB_PCT_B_LONG_HARD_MAX=0.88
SCALP_BB_PCT_B_SHORT_HARD_MIN=0.10
SCALP_VWAP_DELTA_LONG_HARD_MAX=0.30
SCALP_VWAP_DELTA_SHORT_HARD_MAX=0.30
SCALP_STOCH_LONG_MIN_GAP=3.0
SCALP_STOCH_SHORT_MIN_GAP=2.0
SCALP_LONG_MOMENTUM_ENABLED=true
SCALP_LONG_MOMENTUM_GATE_PCT=70
SCALP_LONG_MOMENTUM_MIN_ADX=22
SCALP_LONG_MOMENTUM_MIN_VOL_RATIO=0.90
SCALP_LONG_MOMENTUM_MAX_RSI=72
SCALP_LONG_MOMENTUM_REQUIRE_STOCH_UP=true

# Indicator Thresholds
ATR_MIN=0.004
RSI_LONG_MIN=50.0
RSI_SHORT_MAX=50.0
ADX_MIN=18.0
BBW_MIN=0.015
VOL_REL_MIN=1.2
VWAP_DIST_MIN=0.0015

# Order Book Settings
ORDERBOOK_ENABLED=true
ORDERBOOK_LEVELS=50
ORDERBOOK_TTL_SEC=20
ORDERBOOK_BUCKET_PCT=0.10
WALL_USDT_THRESHOLD=2000000
WALL_NEAR_PCT=1.0

# Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
# LOG_JSON=false

# LLM Guard
# LLM_DISABLED=0

# Quality Scoring (Auto-Post)
QUALITY_SELECT_ENABLED=false
QUALITY_MIN=50
QUALITY_TOP_K=3

# Indicator Preset
INDICATOR_PRESET=preset3
AUTOPOST_PANEL_VERBOSE=false
